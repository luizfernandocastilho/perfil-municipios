# ─── Banco de Dados ───────────────────────────────────────────────────────
POSTGRES_USER=municipios_app
POSTGRES_PASSWORD=changeme_local
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=perfil_municipios
POSTGRES_SCHEMA=municipios
DATABASE_URL=postgresql+asyncpg://municipios_app:changeme_local@localhost:5432/perfil_municipios

# ─── API ──────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_LOG_LEVEL=info
API_CORS_ORIGINS=http://localhost:3000

# ─── Redis (cache) ───────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── ETL ──────────────────────────────────────────────────────────────────
ETL_DATA_DIR=./data
ETL_BATCH_SIZE=1000
ETL_LOG_LEVEL=INFO

# ─── APIs Externas (quando necessário) ───────────────────────────────────
